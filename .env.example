# CodeChronicle Environment Variables
# Copy this file to .env and fill in the values

# ===================
# Django Configuration
# ===================
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Prod-only (Secret Manager lookup in production settings):
# GCP_PROJECT_ID=your-gcp-project-id
# Prod-only if you run with production settings explicitly:
# DJANGO_SETTINGS_MODULE=code_chronicle.settings.production

# ===================
# Database
# ===================
# For local development with SQLite (default if not set)
# DATABASE_URL=sqlite:///db.sqlite3
DATABASE_URL=postgres://postgres:postgres@localhost:5432/code_chronicle

# For PostgreSQL (production)
# DATABASE_URL=postgres://user:password@localhost:5432/code_chronicle

# ===================
# Anthropic (LLM)
# ===================
ANTHROPIC_API_KEY=sk-ant-api-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6


# ===================
# Cloudflare R2 (asset storage) — only needed to run `sync_images --backend r2`
# ===================
# Mint S3 access keys under R2 > Manage R2 API Tokens. The running app does
# NOT need these — assets are served at the edge by a Worker with an R2 binding.
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_BUCKET=codechronicle-assets-prod
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Optional: defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ENDPOINT_URL=

# ===================
# Stripe (Payments)
# ===================
STRIPE_LIVE_SECRET_KEY=sk_live_your-key
STRIPE_TEST_SECRET_KEY=sk_test_your-key
STRIPE_LIVE_MODE=False
STRIPE_PRO_PRICE_ID=price_...

# ===================
# Email (optional for MVP)
# ===================
# Gmail (temporary): use an App Password, not your account password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=you@gmail.com
ACCOUNT_EMAIL_VERIFICATION=mandatory
#
# SendGrid/Postmark/etc (recommended for production scale)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# DEFAULT_FROM_EMAIL=noreply@codechronicle.com
